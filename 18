<!DOCTYPE html>
<html lang="PT-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>botão Troll</title>
</head>
<body>
  <button onmouseover="mensagem()">
    Clique aqui!
  </button>

   <button onclick="teste()">
    Clique aqui!
  </button>

   <button onmousedown="alerta()">
    Clique aqui!
  </button>
<script src="script.js"></script>

</body>
</html>

<!--Java SCRIPT-->
function mensagem(){
    alert("mensagem.")
}

function teste(){
    alert("teste.")
}

function alerta(){
    alert("alerta.")
}
