 <!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sistema de Estatísticas</title>
</head>
<body>

    <h1>Sistema de Estatísticas</h1>

    <button onclick="inserirNumero()">Inserir Número</button>
    <button onclick="mostrarMaior()">Mostrar Maior</button>
    <button onclick="mostrarMenor()">Mostrar Menor</button>

    <script>
        // Vetor para armazenar os números
        let numeros = [];

        function inserirNumero() {
            let numero = parseFloat(prompt("Digite um número:"));

            if (!isNaN(numero)) {
                numeros.push(numero);
                alert("Número armazenado com sucesso!");
            } else {
                alert("Valor inválido.");
            }
        }

        function mostrarMaior() {
            if (numeros.length === 0) {
                alert("Nenhum número cadastrado.");
                return;
            }

            let maior = numeros[0];

            for (let i = 1; i < numeros.length; i++) {
                if (numeros[i] > maior) {
                    maior = numeros[i];
                }
            }

            alert("Maior número: " + maior);
        }

        function mostrarMenor() {
            if (numeros.length === 0) {
                alert("Nenhum número cadastrado.");
                return;
            }

            let menor = numeros[0];

            for (let i = 1; i < numeros.length; i++) {
                if (numeros[i] < menor) {
                    menor = numeros[i];
                }
            }

            alert("Menor número: " + menor);
        }
    </script>

</body>
</html>
