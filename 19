<!DOCTYPE html>
<html lang="PT-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>botão Troll</title>
</head>
<body>
  <button onclick="mensagem()">
    Clique aqui!
  </button>

  <button onmouseover="saudacao()">
    Clique aqui!
  </button>

  <button onmouseover="alerta()">
    Clique aqui!
  </button>
<script src="script.js"></script>

</body>
</html>

<!--Java Script-->

function mensagem(){
    alert("Bom dia!")
}

function saudacao(){
    alert("Boa tarde")
}

function alerta(){
    alert("Boa noite")
}
