<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Central de Operações</title>
</head>
<body>

    <h1>Central de Operações</h1>

    <button onmouseover="mensagem1()">Clique aqui</button>
    <button onmouseout="mensagem2()">Clique aqui</button>
    <button onclick="mensagem3()">Clique aqui</button>


    <script>
       
        function mensagem1() {
            alert("O mouse chegou!");
        }

        function mensagem2() {
            alert("O mouse foi embora!");
        }

        function mensagem3() {
            alert("O mouse clicou em mim!!");
        }
    </script>

</body>
</html>
